><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 218px; height: 1px; padding-top: 1268px; margin-left: 381px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #3fb950; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #3fb950; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">RUNNING<br />Normal operation — BMS SM active</div></div></div></foreignObject><text x="490" y="1271" fill="#3fb950" font-family="Helvetica" font-size="13px" text-anchor="middle">RUNNING...</text></switch></g></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-4"><g><rect x="380" y="1350" width="220" height="55" rx="8.25" ry="8.25" fill="#0d1117" stroke="#f85149" stroke-width="3" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(248, 81, 73);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 218px; height: 1px; padding-top: 1378px; margin-left: 381px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #f85149; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #f85149; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">SYS ERROR<br />Terminal — requires MCU reset</div></div></div></foreignObject><text x="490" y="1381" fill="#f85149" font-family="Helvetica" font-size="13px" text-anchor="middle">SYS ERROR...</text></switch></g></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-5"><g transform="translate(0.5,0.5)"><path d="M 490 1075 L 490 1119.76" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-miterlimit="10" pointer-events="stroke" style="stroke: rgb(