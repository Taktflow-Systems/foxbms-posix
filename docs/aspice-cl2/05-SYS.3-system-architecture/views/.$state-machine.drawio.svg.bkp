oke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="490" y="1327.64">Fatal system error</text></g></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-8"><g transform="translate(0.5,0.5)"><rect x="660" y="1330" width="220" height="70" rx="10.5" ry="10.5" fill="#0d1117" stroke="#f85149" stroke-width="0.5" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(248, 81, 73);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe flex-start; width: 210px; height: 1px; padding-top: 1365px; margin-left: 670px;"><div style="box-sizing: border-box; font-size: 0; text-align: left; color: #9ca3af; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #9ca3af; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">No recovery path.<br />SYS ERROR is terminal.<br />Only MCU reset (SBC watchdog)<br />can restart.</div></div></div></foreignObject><text x="670" y="1369" fill="#9ca3af" font-family="Helvetica" font-size="13px">No recovery path....</text></switch></g></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-9"><g transform="translate(0.5,0.5)"><rect x="240" y="1020" width="90" height="15" fill="none" stroke="none" pointer-events="all"/></g><g><g fill="#FFFFFF" font-family="Helvetica" font-weight="bold" font-size="13px" style="fill: rgb(255, 255, 255);"><text x="242" y="1039">Power-on →</text></g></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-11"><g transform="translate(0.5,0.5)"><path d="M 140 870 L 1520 870" fill="none" stroke="#000000" stroke-miterlimit="10" stroke-dasharray="3 3" pointer-events="stroke" style="stroke: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));"/></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-12"><g transform="t