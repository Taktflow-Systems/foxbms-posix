<!DOCTYPE svg PUBLIC "-//W3C//DTD SVG 1.1//EN" "http://www.w3.org/Graphics/SVG/1.1/DTD/svg11.dtd">
<svg xmlns="http://www.w3.org/2000/svg" style="background: transparent; background-color: transparent; color-scheme: light dark;" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" width="1522px" height="1841px" viewBox="0 0 1522 1841" content="&lt;mxfile host=&quot;Electron&quot; agent=&quot;Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.1 Chrome/142.0.7444.265 Electron/39.8.0 Safari/537.36&quot; version=&quot;29.6.1&quot;&gt;&#10;  &lt;diagram id=&quot;bms-sm&quot; name=&quot;BMS State Machine&quot;&gt;&#10;    &lt;mxGraphModel dx=&quot;2217&quot; dy=&quot;1317&quot; grid=&quot;1&quot; gridSize=&quot;10&quot; guides=&quot;1&quot; tooltips=&quot;1&quot; connect=&quot;1&quot; arrows=&quot;1&quot; fold=&quot;1&quot; page=&quot;0&quot; pageScale=&quot;1&quot; pageWidth=&quot;1400&quot; pageHeight=&quot;850&quot; background=&quot;none&quot; math=&quot;0&quot; shadow=&quot;0&quot;&gt;&#10;      &lt;root&gt;&#10;        &lt;mxCell id=&quot;0&quot; /&gt;&#10;        &lt;mxCell id=&quot;1&quot; parent=&quot;0&quot; /&gt;&#10;        &lt;mxCell id=&quot;title&quot; parent=&quot;1&quot; style=&quot;text;fontSize=13;fontColor=#ffffff;fontStyle=1;align=left;&quot; value=&quot;BMS State Machine&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;25&quot; width=&quot;300&quot; x=&quot;20&quot; y=&quot;10&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;subtitle&quot; parent=&quot;1&quot; style=&quot;text;fontSize=13;fontColor=#6e7681;align=left;&quot; value=&quot;Managed by BMS_Trigger() in 100ms task | ERROR exit requires AND logic (SSR-022 + SSR-023)&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;15&quot; width=&quot;700&quot; x=&quot;20&quot; y=&quot;35&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;standby&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#58a6ff;fontColor=#c9d1d9;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;STANDBY&amp;#xa;&amp;#xa;All contactors OPEN&amp;#xa;Monitoring active&amp;#xa;IVT current = 0 mA&amp;#xa;&amp;#xa;Entry: SYS==RUNNING or ERROR recovery&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;140&quot; width=&quot;270&quot; x=&quot;50&quot; y=&quot;80&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;precharge_s&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#d29922;fontColor=#c9d1d9;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;PRECHARGE&amp;#xa;&amp;#xa;1. Close STRING- (SPS CH1)&amp;#xa;2. Close PRECHARGE (SPS CH2)&amp;#xa;3. Wait V_dc ≈ V_pack (±1000mV)&amp;#xa;4. Close STRING+ (SPS CH0), open PRE&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;160&quot; width=&quot;350&quot; x=&quot;500&quot; y=&quot;80&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;normal&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#c9d1d9;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;NORMAL&amp;#xa;&amp;#xa;All 3 contactors CLOSED&amp;#xa;Full power operation&amp;#xa;SOA checks active every 10ms&amp;#xa;IVT current = load current&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;150&quot; width=&quot;350&quot; x=&quot;500&quot; y=&quot;350&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;error&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#f85149;fontColor=#c9d1d9;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;ERROR (Safe State)&amp;#xa;&amp;#xa;All contactors OPEN (CONT_OpenAll)&amp;#xa;State is LATCHED — no auto-recover&amp;#xa;&amp;#xa;EXIT requires BOTH (AND logic):&amp;#xa;SSR-022: Fault condition CLEARED&amp;#xa;SSR-023: CAN 0x210 STANDBY request&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;180&quot; width=&quot;350&quot; x=&quot;500&quot; y=&quot;600&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_s_p&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;standby&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#3fb950;fontStyle=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;&quot; target=&quot;precharge_s&quot; value=&quot;CAN 0x210 = NORMAL request&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; y=&quot;-20&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;mxPoint as=&quot;offset&quot; /&gt;&#10;            &lt;Array as=&quot;points&quot;&gt;&#10;              &lt;mxPoint x=&quot;460&quot; y=&quot;160&quot; /&gt;&#10;              &lt;mxPoint x=&quot;460&quot; y=&quot;160&quot; /&gt;&#10;            &lt;/Array&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_p_n&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;precharge_s&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#3fb950;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;&quot; target=&quot;normal&quot; value=&quot;Voltage match within threshold&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_p_e&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;precharge_s&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=2;dashed=1;dashPattern=6 3;endArrow=block;endFill=1;fontSize=13;fontColor=#f85149;exitX=1;exitY=1;entryX=1;entryY=0;&quot; target=&quot;error&quot; value=&quot;Timeout or 3 retries fail&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; x=&quot;0.0435&quot; y=&quot;70&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;mxPoint as=&quot;offset&quot; /&gt;&#10;            &lt;Array as=&quot;points&quot;&gt;&#10;              &lt;mxPoint x=&quot;900&quot; y=&quot;240&quot; /&gt;&#10;              &lt;mxPoint x=&quot;900&quot; y=&quot;600&quot; /&gt;&#10;            &lt;/Array&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_n_s&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;normal&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#58a6ff;fontStyle=1;exitX=0;exitY=0.5;&quot; value=&quot;CAN 0x210 = STANDBY request&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;Array as=&quot;points&quot;&gt;&#10;              &lt;mxPoint x=&quot;190&quot; y=&quot;425&quot; /&gt;&#10;            &lt;/Array&gt;&#10;            &lt;mxPoint x=&quot;190&quot; y=&quot;221&quot; as=&quot;targetPoint&quot; /&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_n_e&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;normal&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;fontColor=#f85149;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;&quot; target=&quot;error&quot; value=&quot;ANY MSL violation (DIAG FATAL)&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;t_e_s&quot; edge=&quot;1&quot; parent=&quot;1&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;dashed=1;dashPattern=8 4;endArrow=block;endFill=1;fontSize=13;fontColor=#58a6ff;entryX=0.321;entryY=1.01;entryDx=0;entryDy=0;entryPerimeter=0;&quot; target=&quot;standby&quot; value=&quot;Fault cleared AND STANDBY requested (SSR-022 + SSR-023)&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;Array as=&quot;points&quot;&gt;&#10;              &lt;mxPoint x=&quot;500&quot; y=&quot;700&quot; /&gt;&#10;              &lt;mxPoint x=&quot;500&quot; y=&quot;701&quot; /&gt;&#10;              &lt;mxPoint x=&quot;137&quot; y=&quot;701&quot; /&gt;&#10;            &lt;/Array&gt;&#10;            &lt;mxPoint x=&quot;460&quot; y=&quot;700&quot; as=&quot;sourcePoint&quot; /&gt;&#10;            &lt;mxPoint x=&quot;132.07999999999993&quot; y=&quot;229.99999999999997&quot; as=&quot;targetPoint&quot; /&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;faults&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#30363d;fontColor=#fca5a5;fontSize=13;align=left;spacingLeft=10;&quot; value=&quot;Faults that trigger ERROR:&amp;#xa;&amp;#xa;TSR-01: Cell OV &amp;gt; 2800mV (FTTI 750ms)&amp;#xa;TSR-02: Cell UV &amp;lt; 1500mV (FTTI 750ms)&amp;#xa;TSR-04/05: Overcurrent (FTTI 250ms)&amp;#xa;TSR-06/07: Over/undertemp (FTTI 6050ms)&amp;#xa;TSR-08: Contactor FB mismatch (350ms)&amp;#xa;TSR-09: IVT comms loss (1250ms)&amp;#xa;TSR-10: AFE comms loss (200ms)&amp;#xa;TSR-13: Interlock break (250ms)&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;180&quot; width=&quot;280&quot; x=&quot;990&quot; y=&quot;610&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;w_faults&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;faults&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;strokeColor=#f85149;strokeWidth=1;dashed=1;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;error&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;Array as=&quot;points&quot;&gt;&#10;              &lt;mxPoint x=&quot;940&quot; y=&quot;690&quot; /&gt;&#10;              &lt;mxPoint x=&quot;940&quot; y=&quot;690&quot; /&gt;&#10;            &lt;/Array&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-1&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#6e7681;fontColor=#c9d1d9;fontSize=13;strokeWidth=2;align=center;&quot; value=&quot;UNINITIALIZED&amp;#xa;Power-on reset&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;55&quot; width=&quot;220&quot; x=&quot;210&quot; y=&quot;1030&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-2&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#8b5cf6;fontColor=#c4b5fd;fontSize=13;strokeWidth=2;align=center;&quot; value=&quot;INITIALIZED&amp;#xa;OS started, tasks created&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;55&quot; width=&quot;220&quot; x=&quot;210&quot; y=&quot;1140&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-3&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#3fb950;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;RUNNING&amp;#xa;Normal operation — BMS SM active&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;55&quot; width=&quot;220&quot; x=&quot;210&quot; y=&quot;1250&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-4&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#f85149;fontColor=#f85149;fontSize=13;strokeWidth=3;align=center;&quot; value=&quot;SYS ERROR&amp;#xa;Terminal — requires MCU reset&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;55&quot; width=&quot;220&quot; x=&quot;210&quot; y=&quot;1360&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-5&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;Zvs2Y6NIQx1uEkYGQ_RT-1&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;strokeColor=#8b5cf6;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#8b5cf6;&quot; target=&quot;Zvs2Y6NIQx1uEkYGQ_RT-2&quot; value=&quot;HW init complete&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-6&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;Zvs2Y6NIQx1uEkYGQ_RT-2&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;strokeColor=#8b5cf6;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#8b5cf6;&quot; target=&quot;Zvs2Y6NIQx1uEkYGQ_RT-3&quot; value=&quot;All subsystems ready&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-7&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;Zvs2Y6NIQx1uEkYGQ_RT-3&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;fontColor=#f85149;&quot; target=&quot;Zvs2Y6NIQx1uEkYGQ_RT-4&quot; value=&quot;Fatal system error&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-8&quot; parent=&quot;1&quot; style=&quot;rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#f85149;strokeWidth=0.5;fontColor=#9ca3af;fontSize=13;align=left;spacingLeft=8;&quot; value=&quot;No recovery path.&amp;#xa;SYS ERROR is terminal.&amp;#xa;Only MCU reset (SBC watchdog)&amp;#xa;can restart.&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;70&quot; width=&quot;220&quot; x=&quot;490&quot; y=&quot;1340&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-9&quot; parent=&quot;1&quot; style=&quot;text;fontSize=13;fontColor=#FFFFFF;fontStyle=1;&quot; value=&quot;Power-on →&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;15&quot; width=&quot;90&quot; x=&quot;70&quot; y=&quot;1030&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-11&quot; edge=&quot;1&quot; parent=&quot;1&quot; style=&quot;endArrow=none;dashed=1;html=1;rounded=0;fontSize=13;&quot; value=&quot;&quot;&gt;&#10;          &lt;mxGeometry height=&quot;50&quot; relative=&quot;1&quot; width=&quot;50&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;mxPoint x=&quot;-30&quot; y=&quot;880&quot; as=&quot;sourcePoint&quot; /&gt;&#10;            &lt;mxPoint x=&quot;1350&quot; y=&quot;880&quot; as=&quot;targetPoint&quot; /&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-12&quot; parent=&quot;1&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fontSize=13;&quot; value=&quot;&amp;lt;font style=&amp;quot;color: rgb(102, 255, 102);&amp;quot;&amp;gt;BMS State Machine&amp;lt;/font&amp;gt;&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;120&quot; x=&quot;-150&quot; y=&quot;410&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;Zvs2Y6NIQx1uEkYGQ_RT-13&quot; parent=&quot;1&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fontSize=13;&quot; value=&quot;&amp;lt;font style=&amp;quot;color: rgb(102, 255, 102);&amp;quot;&amp;gt;SYS State Machine&amp;lt;/font&amp;gt;&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;120&quot; x=&quot;-160&quot; y=&quot;1130&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;obQx08zKhbk9wwHqWU4G-1&quot; edge=&quot;1&quot; parent=&quot;1&quot; style=&quot;endArrow=none;dashed=1;html=1;rounded=0;fontSize=13;&quot; value=&quot;&quot;&gt;&#10;          &lt;mxGeometry height=&quot;50&quot; relative=&quot;1&quot; width=&quot;50&quot; as=&quot;geometry&quot;&gt;&#10;            &lt;mxPoint x=&quot;-50&quot; y=&quot;1530&quot; as=&quot;sourcePoint&quot; /&gt;&#10;            &lt;mxPoint x=&quot;1330&quot; y=&quot;1530&quot; as=&quot;targetPoint&quot; /&gt;&#10;          &lt;/mxGeometry&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-1&quot; parent=&quot;1&quot; style=&quot;text;fontSize=13;fontColor=#ffffff;fontStyle=1;align=left;&quot; value=&quot;Fault Reaction Timeline — TSR-01 Cell Overvoltage (ASIL D, FTTI 750ms)&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;20&quot; width=&quot;600&quot; x=&quot;50&quot; y=&quot;1610&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-2&quot; parent=&quot;1&quot; style=&quot;rounded=0;fillColor=none;strokeColor=#f85149;strokeWidth=1;dashed=1;dashPattern=6 3;fontSize=13;&quot; value=&quot;&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;200&quot; width=&quot;1220&quot; x=&quot;60&quot; y=&quot;1650&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-3&quot; parent=&quot;1&quot; style=&quot;text;fontSize=13;fontColor=#f85149;fontStyle=1;align=center;&quot; value=&quot;FTTI = 750ms&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;20&quot; width=&quot;120&quot; x=&quot;430&quot; y=&quot;1635&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-4&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#fca5a5;fontSize=13;strokeWidth=2;align=center;&quot; value=&quot;t₀&amp;#xa;Cell &amp;gt; 2800mV&amp;#xa;Fault occurs&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;105&quot; x=&quot;70&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-18&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-5&quot; style=&quot;edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-4&quot; value=&quot;&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-5&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=13;align=center;&quot; value=&quot;+10ms&amp;#xa;SOA detects&amp;#xa;Counter: 0→1&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;85&quot; x=&quot;200&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-6&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=13;align=center;&quot; value=&quot;Threshold accumulation&amp;#xa;50 × 10ms = 500ms&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;170&quot; x=&quot;320&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-7&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#f85149;fontSize=13;align=center;&quot; value=&quot;Debounce&amp;#xa;200ms delay&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;130&quot; x=&quot;520&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-8&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#fca5a5;fontSize=13;strokeWidth=2;align=center;&quot; value=&quot;+700ms&amp;#xa;FATAL SET&amp;#xa;BMS → ERROR&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;120&quot; x=&quot;670&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-9&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#3fb950;fontSize=13;align=center;&quot; value=&quot;SPS cmd&amp;#xa;Coils off&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;70&quot; x=&quot;820&quot; y=&quot;1680&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-10&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#3fb950;fontSize=13;strokeWidth=3;fontStyle=1;align=center;&quot; value=&quot;+750ms&amp;#xa;SAFE STATE&amp;#xa;Contactors OPEN&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;80&quot; width=&quot;120&quot; x=&quot;990&quot; y=&quot;1670&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-11&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-4&quot; style=&quot;strokeColor=#d29922;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-5&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-12&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-5&quot; style=&quot;strokeColor=#d29922;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-6&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-13&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-6&quot; style=&quot;strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-7&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-14&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-7&quot; style=&quot;strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-8&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-15&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-8&quot; style=&quot;strokeColor=#3fb950;strokeWidth=2;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-9&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-16&quot; edge=&quot;1&quot; parent=&quot;1&quot; source=&quot;WBZhySPWgRbXWCMWS487-9&quot; style=&quot;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=13;&quot; target=&quot;WBZhySPWgRbXWCMWS487-10&quot;&gt;&#10;          &lt;mxGeometry relative=&quot;1&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-17&quot; parent=&quot;1&quot; style=&quot;rounded=1;fillColor=#0d1117;strokeColor=#30363d;fontColor=#B9E0A5;fontSize=15;align=left;spacingLeft=8;&quot; value=&quot;Call chain: SOA_CheckCellVoltage() → DIAG_Handler() → FATAL → BMS_Trigger() → BMS_ERROR → CONT_OpenAll() → spiREG2 → SPS IC → contactor spring-open&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;25&quot; width=&quot;880&quot; x=&quot;90&quot; y=&quot;1780&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;        &lt;mxCell id=&quot;WBZhySPWgRbXWCMWS487-21&quot; parent=&quot;1&quot; style=&quot;rounded=0;whiteSpace=wrap;html=1;fontSize=13;&quot; value=&quot;&amp;lt;font style=&amp;quot;color: rgb(102, 255, 102);&amp;quot;&amp;gt;Fault Reaction Timeline&amp;lt;/font&amp;gt;&quot; vertex=&quot;1&quot;&gt;&#10;          &lt;mxGeometry height=&quot;60&quot; width=&quot;160&quot; x=&quot;-170&quot; y=&quot;1700&quot; as=&quot;geometry&quot; /&gt;&#10;        &lt;/mxCell&gt;&#10;      &lt;/root&gt;&#10;    &lt;/mxGraphModel&gt;&#10;  &lt;/diagram&gt;&#10;&lt;/mxfile&gt;&#10;"><defs/><g><g data-cell-id="0"><g data-cell-id="1"><g data-cell-id="title"><g transform="translate(0.5,0.5)"><rect x="190" y="0" width="300" height="25" fill="none" stroke="none" pointer-events="all"/></g><g><g fill="#ffffff" font-family="Helvetica" font-weight="bold" font-size="13px" style="fill: rgb(255, 255, 255);"><text x="192" y="19">BMS State Machine</text></g></g></g><g data-cell-id="subtitle"><g transform="translate(0.5,0.5)"><rect x="190" y="25" width="700" height="15" fill="none" stroke="none" pointer-events="all"/></g><g><g fill="#6e7681" font-family="Helvetica" font-size="13px" style="fill: rgb(110, 118, 129);"><text x="192" y="44">Managed by BMS_Trigger() in 100ms task | ERROR exit requires AND logic (SSR-022 + SSR-023)</text></g></g></g><g data-cell-id="standby"><g><rect x="220" y="70" width="270" height="140" rx="21" ry="21" fill="#0d1117" stroke="#58a6ff" stroke-width="3" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(88, 166, 255);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 268px; height: 1px; padding-top: 140px; margin-left: 221px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #c9d1d9; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #c9d1d9; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">STANDBY<br /><br />All contactors OPEN<br />Monitoring active<br />IVT current = 0 mA<br /><br />Entry: SYS==RUNNING or ERROR recovery</div></div></div></foreignObject><text x="355" y="144" fill="#c9d1d9" font-family="Helvetica" font-size="13px" text-anchor="middle">STANDBY...</text></switch></g></g></g><g data-cell-id="precharge_s"><g><rect x="670" y="70" width="350" height="160" rx="24" ry="24" fill="#0d1117" stroke="#d29922" stroke-width="3" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(210, 153, 34);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 348px; height: 1px; padding-top: 150px; margin-left: 671px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #c9d1d9; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #c9d1d9; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">PRECHARGE<br /><br />1. Close STRING- (SPS CH1)<br />2. Close PRECHARGE (SPS CH2)<br />3. Wait V_dc ≈ V_pack (±1000mV)<br />4. Close STRING+ (SPS CH0), open PRE</div></div></div></foreignObject><text x="845" y="154" fill="#c9d1d9" font-family="Helvetica" font-size="13px" text-anchor="middle">PRECHARGE...</text></switch></g></g></g><g data-cell-id="normal"><g><rect x="670" y="340" width="350" height="150" rx="22.5" ry="22.5" fill="#0d1117" stroke="#3fb950" stroke-width="3" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(63, 185, 80);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 348px; height: 1px; padding-top: 415px; margin-left: 671px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #c9d1d9; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #c9d1d9; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">NORMAL<br /><br />All 3 contactors CLOSED<br />Full power operation<br />SOA checks active every 10ms<br />IVT current = load current</div></div></div></foreignObject><text x="845" y="419" fill="#c9d1d9" font-family="Helvetica" font-size="13px" text-anchor="middle">NORMAL...</text></switch></g></g></g><g data-cell-id="error"><g><rect x="670" y="590" width="350" height="180" rx="27" ry="27" fill="#0d1117" stroke="#f85149" stroke-width="3" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(248, 81, 73);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 348px; height: 1px; padding-top: 680px; margin-left: 671px;"><div style="box-sizing: border-box; font-size: 0; text-align: center; color: #c9d1d9; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #c9d1d9; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">ERROR (Safe State)<br /><br />All contactors OPEN (CONT_OpenAll)<br />State is LATCHED — no auto-recover<br /><br />EXIT requires BOTH (AND logic):<br />SSR-022: Fault condition CLEARED<br />SSR-023: CAN 0x210 STANDBY request</div></div></div></foreignObject><text x="845" y="684" fill="#c9d1d9" font-family="Helvetica" font-size="13px" text-anchor="middle">ERROR (Safe State)...</text></switch></g></g></g><g data-cell-id="t_s_p"><g><path d="M 490 150 L 620 150 Q 630 150 640 150 L 657.65 150" fill="none" stroke="#3fb950" stroke-width="3" stroke-miterlimit="10" pointer-events="stroke" style="stroke: rgb(63, 185, 80);"/><path d="M 666.65 150 L 657.65 154.5 L 657.65 145.5 Z" fill="#3fb950" stroke="#3fb950" stroke-width="3" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(63, 185, 80); stroke: rgb(63, 185, 80);"/></g><g><g fill="#3fb950" font-family="Helvetica" font-weight="bold" text-anchor="middle" font-size="13px" style="fill: rgb(63, 185, 80);"><rect fill="#ffffff" stroke="none" x="485" y="163" width="192" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="580" y="175.5">CAN 0x210 = NORMAL request</text></g></g></g><g data-cell-id="t_p_n"><g><path d="M 845 230 L 845 327.65" fill="none" stroke="#3fb950" stroke-width="3" stroke-miterlimit="10" pointer-events="stroke" style="stroke: rgb(63, 185, 80);"/><path d="M 845 336.65 L 840.5 327.65 L 849.5 327.65 Z" fill="#3fb950" stroke="#3fb950" stroke-width="3" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(63, 185, 80); stroke: rgb(63, 185, 80);"/></g><g><g fill="#3fb950" font-family="Helvetica" font-weight="bold" text-anchor="middle" font-size="13px" style="fill: rgb(63, 185, 80);"><rect fill="#ffffff" stroke="none" x="749" y="277" width="194" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="845" y="289.79">Voltage match within threshold</text></g></g></g><g data-cell-id="t_p_e"><g transform="translate(0.5,0.5)"><path d="M 1020 230 L 1060 230 Q 1070 230 1070 240 L 1070 580 Q 1070 590 1060 590 L 1030.24 590" fill="none" stroke="#f85149" stroke-width="2" stroke-miterlimit="10" stroke-dasharray="12 6" pointer-events="stroke" style="stroke: rgb(248, 81, 73);"/><path d="M 1022.24 590 L 1030.24 586 L 1030.24 594 Z" fill="#f85149" stroke="#f85149" stroke-width="2" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(248, 81, 73); stroke: rgb(248, 81, 73);"/></g><g><g fill="#f85149" font-family="Helvetica" text-anchor="middle" font-size="13px" style="fill: rgb(248, 81, 73);"><rect fill="#ffffff" stroke="none" x="1074" y="412" width="134" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="1140" y="425.5">Timeout or 3 retries fail</text></g></g></g><g data-cell-id="t_n_s"><g transform="translate(0.5,0.5)"><path d="M 670 415 L 370 415 Q 360 415 360 405 L 360 221.24" fill="none" stroke="#58a6ff" stroke-width="2" stroke-miterlimit="10" pointer-events="stroke" style="stroke: rgb(88, 166, 255);"/><path d="M 360 213.24 L 364 221.24 L 356 221.24 Z" fill="#58a6ff" stroke="#58a6ff" stroke-width="2" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(88, 166, 255); stroke: rgb(88, 166, 255);"/></g><g><g fill="#58a6ff" font-family="Helvetica" font-weight="bold" text-anchor="middle" font-size="13px" style="fill: rgb(88, 166, 255);"><rect fill="#ffffff" stroke="none" x="315" y="408" width="197" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="412.86" y="420.5">CAN 0x210 = STANDBY request</text></g></g></g><g data-cell-id="t_n_e"><g><path d="M 845 490 L 845 577.65" fill="none" stroke="#f85149" stroke-width="3" stroke-miterlimit="10" pointer-events="stroke" style="stroke: rgb(248, 81, 73);"/><path d="M 845 586.65 L 840.5 577.65 L 849.5 577.65 Z" fill="#f85149" stroke="#f85149" stroke-width="3" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(248, 81, 73); stroke: rgb(248, 81, 73);"/></g><g><g fill="#f85149" font-family="Helvetica" font-weight="bold" text-anchor="middle" font-size="13px" style="fill: rgb(248, 81, 73);"><rect fill="#ffffff" stroke="none" x="743" y="533" width="205" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="845" y="545.5">ANY MSL violation (DIAG FATAL)</text></g></g></g><g data-cell-id="t_e_s"><g transform="translate(0.5,0.5)"><path d="M 630 690 L 660 690 Q 670 690 660 690.03 L 316.71 690.97 Q 306.71 691 306.71 681 L 306.67 221.64" fill="none" stroke="#58a6ff" stroke-width="2" stroke-miterlimit="10" stroke-dasharray="16 8" pointer-events="stroke" style="stroke: rgb(88, 166, 255);"/><path d="M 306.67 213.64 L 310.67 221.64 L 302.67 221.64 Z" fill="#58a6ff" stroke="#58a6ff" stroke-width="2" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(88, 166, 255); stroke: rgb(88, 166, 255);"/></g><g><g fill="#58a6ff" font-family="Helvetica" text-anchor="middle" font-size="13px" style="fill: rgb(88, 166, 255);"><rect fill="#ffffff" stroke="none" x="125" y="645" width="365" height="17" stroke-width="0" style="fill: light-dark(#ffffff, var(--ge-dark-color, #121212));"/><text x="306.71" y="658.36">Fault cleared AND STANDBY requested (SSR-022 + SSR-023)</text></g></g></g><g data-cell-id="faults"><g transform="translate(0.5,0.5)"><rect x="1160" y="600" width="280" height="180" rx="27" ry="27" fill="#0d1117" stroke="#30363d" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(48, 54, 61);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe flex-start; width: 268px; height: 1px; padding-top: 690px; margin-left: 1172px;"><div style="box-sizing: border-box; font-size: 0; text-align: left; color: #fca5a5; "><div style="display: inline-block; font-size: 13px; font-family: Helvetica; color: #fca5a5; line-height: 1.2; pointer-events: all; white-space: normal; word-wrap: normal; ">Faults that trigger ERROR:<br /><br />TSR-01: Cell OV &gt; 2800mV (FTTI 750ms)<br />TSR-02: Cell UV &lt; 1500mV (FTTI 750ms)<br />TSR-04/05: Overcurrent (FTTI 250ms)<br />TSR-06/07: Over/undertemp (FTTI 6050ms)<br />TSR-08: Contactor FB mismatch (350ms)<br />TSR-09: IVT comms loss (1250ms)<br />TSR-10: AFE comms loss (200ms)<br />TSR-13: Interlock break (250ms)</div></div></div></foreignObject><text x="1172" y="694" fill="#fca5a5" font-family="Helvetica" font-size="13px">Faults that trigger ERROR:...</text></switch></g></g></g><g data-cell-id="w_faults"><g transform="translate(0.5,0.5)"><path d="M 1160 680 L 1120 680 Q 1110 680 1100 680 L 1028.12 680" fill="none" stroke="#f85149" stroke-miterlimit="10" stroke-dasharray="3 3" pointer-events="stroke" style="stroke: rgb(248, 81, 73);"/><path d="M 1021.12 680 L 1028.12 676.5 L 1028.12 683.5 Z" fill="#f85149" stroke="#f85149" stroke-miterlimit="10" pointer-events="all" style="fill: rgb(248, 81, 73); stroke: rgb(248, 81, 73);"/></g></g><g data-cell-id="Zvs2Y6NIQx1uEkYGQ_RT-1"><g transform="translate(0.5,0.5)"><rect x="380" y="1020" width="220" height="55" rx="8.25" ry="8.25" fill="#0d1117" stroke="#6e7681" stroke-width="2" pointer-events="all" style="fill: rgb(13, 17, 23); stroke: rgb(110, 118, 129);"/></g><g><g><switch><foreignObject style="overflow: visible; text-align: left;" pointer-events="none" width="100%" height="100%" requiredFeatures="http://www.w3.org/TR/SVG11/feature#Extensibility"><div xmlns="http://www.w3.org/1999/xhtml" style="display: flex; align-items: unsafe center; justify-content: unsafe center; width: 218px; height: 1px; padding-top: 1048px; margin-left: 381px;"><div style="box-sizing: border-box; font-si