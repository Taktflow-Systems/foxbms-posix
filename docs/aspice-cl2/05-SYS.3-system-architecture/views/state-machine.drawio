<mxfile host="VSCode" modified="2026-03-23T23:30:00.000Z" agent="Claude">
  <diagram id="bms-sm" name="BMS State Machine">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="850" background="#0d1117">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;font color='#ffffff' style='font-size:16px'&gt;&lt;b&gt;BMS State Machine&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color='#6e7681' size='1'&gt;Managed by BMS_Trigger() in 100ms task | Controls contactor states | ERROR exit requires AND logic (SSR-022 + SSR-023)&lt;/font&gt;" style="text;html=1;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="10" width="700" height="40" as="geometry"/>
        </mxCell>

        <!-- STANDBY -->
        <mxCell id="standby" value="&lt;font size='4'&gt;&lt;b&gt;STANDBY&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;All contactors OPEN&lt;br&gt;Monitoring active&lt;br&gt;IVT current = 0 mA&lt;br&gt;&lt;br&gt;&lt;font size='1' color='#58a6ff'&gt;Entry: SYS==RUNNING or ERROR recovery&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#58a6ff;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="50" y="80" width="300" height="160" as="geometry"/>
        </mxCell>

        <!-- PRECHARGE -->
        <mxCell id="precharge_s" value="&lt;font size='4'&gt;&lt;b&gt;PRECHARGE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color='#d29922'&gt;&lt;b&gt;1.&lt;/b&gt; Close STRING− (SPS CH1)&lt;br&gt;&lt;b&gt;2.&lt;/b&gt; Close PRECHARGE (SPS CH2)&lt;br&gt;&lt;b&gt;3.&lt;/b&gt; Wait V_dc ≈ V_pack (±1000mV)&lt;br&gt;&lt;b&gt;4.&lt;/b&gt; Close STRING+ (SPS CH0), open PRE&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="500" y="80" width="350" height="160" as="geometry"/>
        </mxCell>

        <!-- NORMAL -->
        <mxCell id="normal" value="&lt;font size='4'&gt;&lt;b&gt;NORMAL&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;All 3 contactors CLOSED&lt;br&gt;Full power operation&lt;br&gt;SOA checks active every 10ms&lt;br&gt;IVT current = load current" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="500" y="350" width="350" height="150" as="geometry"/>
        </mxCell>

        <!-- ERROR -->
        <mxCell id="error" value="&lt;font size='4' color='#f85149'&gt;&lt;b&gt;ERROR (Safe State)&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;All contactors OPEN (CONT_OpenAll)&lt;br&gt;State is LATCHED — no auto-recover&lt;br&gt;&lt;br&gt;&lt;font color='#f85149'&gt;&lt;b&gt;EXIT requires BOTH (AND logic):&lt;/b&gt;&lt;br&gt;SSR-022: Fault condition CLEARED&lt;br&gt;SSR-023: CAN 0x210 STANDBY request&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="500" y="600" width="350" height="180" as="geometry"/>
        </mxCell>

        <!-- Transitions -->
        <!-- STANDBY → PRECHARGE -->
        <mxCell id="t_s_p" value="&lt;font color='#3fb950'&gt;&lt;b&gt;CAN 0x210&lt;br&gt;= NORMAL request&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=8;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" parent="1" source="standby" target="precharge_s" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PRECHARGE → NORMAL (success) -->
        <mxCell id="t_p_n" value="&lt;font color='#3fb950'&gt;&lt;b&gt;Voltage match&lt;br&gt;within threshold&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=8;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="precharge_s" target="normal" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PRECHARGE → ERROR (fail) -->
        <mxCell id="t_p_e" value="&lt;font color='#f85149'&gt;Timeout or&lt;br&gt;3 retries fail&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=2;dashed=1;dashPattern=6 3;endArrow=block;endFill=1;fontSize=8;exitX=1;exitY=1;entryX=1;entryY=0;" parent="1" source="precharge_s" target="error" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- NORMAL → STANDBY (graceful) -->
        <mxCell id="t_n_s" value="&lt;font color='#58a6ff'&gt;&lt;b&gt;CAN 0x210&lt;br&gt;= STANDBY request&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;exitX=0;exitY=0.5;entryX=0;entryY=1;" parent="1" source="normal" target="standby" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="30" y="425"/><mxPoint x="30" y="240"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- NORMAL → ERROR (fault) -->
        <mxCell id="t_n_e" value="&lt;font color='#f85149'&gt;&lt;b&gt;ANY MSL violation&lt;br&gt;(DIAG FATAL flag set)&lt;/b&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=3;endArrow=block;endFill=1;fontSize=9;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="normal" target="error" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ERROR → STANDBY (recovery) -->
        <mxCell id="t_e_s" value="&lt;font color='#58a6ff'&gt;&lt;b&gt;Fault cleared AND&lt;br&gt;STANDBY requested&lt;/b&gt;&lt;br&gt;&lt;font size='1'&gt;(SSR-022 ∧ SSR-023 ∧ SSR-024)&lt;/font&gt;&lt;/font&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;dashed=1;dashPattern=8 4;endArrow=block;endFill=1;fontSize=8;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" parent="1" source="error" target="standby" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="200" y="690"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- Fault sources box -->
        <mxCell id="faults" value="&lt;b&gt;Faults that trigger ERROR:&lt;/b&gt;&lt;br&gt;&lt;font color='#fca5a5'&gt;TSR-01: Cell OV &amp;gt; 2800mV (FTTI 750ms)&lt;br&gt;TSR-02: Cell UV &amp;lt; 1500mV (FTTI 750ms)&lt;br&gt;TSR-04/05: Overcurrent (FTTI 250ms)&lt;br&gt;TSR-06/07: Over/undertemp (FTTI 6050ms)&lt;br&gt;TSR-08: Contactor FB mismatch (350ms)&lt;br&gt;TSR-09: IVT comms loss (1250ms)&lt;br&gt;TSR-10: AFE comms loss (200ms)&lt;br&gt;TSR-13: Interlock break (250ms)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;fontColor=#c9d1d9;fontSize=8;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="950" y="350" width="250" height="160" as="geometry"/>
        </mxCell>

        <!-- Arrow from faults to ERROR -->
        <mxCell id="w_faults" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f85149;strokeWidth=1;dashed=1;endArrow=block;endFill=1;" parent="1" source="faults" target="error" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="sys-sm" name="SYS State Machine">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="800" pageHeight="500" background="#0d1117">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="uninit" value="&lt;b&gt;UNINITIALIZED&lt;/b&gt;&lt;br&gt;&lt;font size='1' color='#6e7681'&gt;Power-on reset&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#6e7681;fontColor=#c9d1d9;fontSize=12;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="250" y="20" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="init" value="&lt;b&gt;INITIALIZED&lt;/b&gt;&lt;br&gt;&lt;font size='1' color='#6e7681'&gt;OS started, tasks created&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#8b5cf6;fontColor=#c4b5fd;fontSize=12;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="250" y="130" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="running" value="&lt;b&gt;RUNNING&lt;/b&gt;&lt;br&gt;&lt;font size='1' color='#6e7681'&gt;Normal operation — BMS SM active&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#3fb950;fontSize=12;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="250" y="240" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="sys_err" value="&lt;b&gt;SYS ERROR&lt;/b&gt;&lt;br&gt;&lt;font size='1' color='#6e7681'&gt;Terminal — requires MCU reset&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#f85149;fontSize=12;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="250" y="350" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="HW init complete" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#8b5cf6;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;fontColor=#8b5cf6;" parent="1" source="uninit" target="init" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t2" value="All subsystems ready" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#8b5cf6;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;fontColor=#8b5cf6;" parent="1" source="init" target="running" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="t3" value="Fatal system error" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;fontSize=8;fontColor=#f85149;" parent="1" source="running" target="sys_err" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="no_recovery" value="&lt;font color='#f85149'&gt;&lt;b&gt;No recovery path&lt;/b&gt;&lt;br&gt;SYS ERROR is terminal.&lt;br&gt;Only MCU reset (SBC watchdog)&lt;br&gt;can restart.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;strokeWidth=0.5;fontColor=#9ca3af;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="530" y="330" width="200" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="pwr_lbl" value="&lt;b&gt;Power-on →&lt;/b&gt;" style="text;html=1;fontSize=9;fontColor=#6e7681;" parent="1" vertex="1">
          <mxGeometry x="160" y="35" width="80" height="15" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="fault-seq" name="Fault Reaction Timeline">
    <mxGraphModel dx="1400" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="350" background="#0d1117">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="ftitle" value="&lt;font color='#fff' size='3'&gt;&lt;b&gt;Fault Reaction Timeline — TSR-01 Cell Overvoltage (ASIL D, FTTI 750ms)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="10" width="600" height="20" as="geometry"/>
        </mxCell>

        <!-- FTTI bar -->
        <mxCell id="ftti_bar" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#f85149;strokeWidth=1;dashed=1;dashPattern=6 3;" parent="1" vertex="1">
          <mxGeometry x="60" y="50" width="850" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="ftti_lbl" value="&lt;font color='#f85149' size='3'&gt;&lt;b&gt;FTTI = 750ms&lt;/b&gt;&lt;/font&gt;" style="text;html=1;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="400" y="40" width="120" height="20" as="geometry"/>
        </mxCell>

        <!-- Timeline phases -->
        <mxCell id="ph_fault" value="&lt;b&gt;t₀&lt;/b&gt;&lt;br&gt;&lt;font color='#f85149'&gt;Cell &amp;gt; 2800mV&lt;br&gt;Fault occurs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#c9d1d9;fontSize=8;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="60" y="80" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_detect" value="&lt;b&gt;+10ms&lt;/b&gt;&lt;br&gt;SOA detects&lt;br&gt;Counter: 0→1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="160" y="80" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_thresh" value="&lt;b&gt;Threshold accumulation&lt;/b&gt;&lt;br&gt;50 × 10ms = 500ms&lt;br&gt;&lt;font size='1' color='#6e7681'&gt;DIAG counter increments&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="260" y="80" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_debounce" value="&lt;b&gt;Debounce&lt;/b&gt;&lt;br&gt;200ms delay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#f85149;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="480" y="80" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_fatal" value="&lt;b&gt;+700ms&lt;/b&gt;&lt;br&gt;&lt;font color='#f85149'&gt;FATAL SET&lt;br&gt;BMS → ERROR&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#c9d1d9;fontSize=8;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="600" y="80" width="80" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_sps" value="&lt;b&gt;SPS cmd&lt;/b&gt;&lt;br&gt;Coils off" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#3fb950;fontSize=8;" parent="1" vertex="1">
          <mxGeometry x="700" y="80" width="70" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ph_open" value="&lt;b&gt;+750ms&lt;/b&gt;&lt;br&gt;&lt;font color='#3fb950' size='3'&gt;&lt;b&gt;SAFE STATE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Contactors OPEN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#c9d1d9;fontSize=8;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="790" y="70" width="110" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows between phases -->
        <mxCell id="a1" style="strokeColor=#d29922;strokeWidth=2;endArrow=block;endFill=1;" parent="1" source="ph_fault" target="ph_detect" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="strokeColor=#d29922;strokeWidth=2;endArrow=block;endFill=1;" parent="1" source="ph_detect" target="ph_thresh" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;" parent="1" source="ph_thresh" target="ph_debounce" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a4" style="strokeColor=#f85149;strokeWidth=2;endArrow=block;endFill=1;" parent="1" source="ph_debounce" target="ph_fatal" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a5" style="strokeColor=#3fb950;strokeWidth=2;endArrow=block;endFill=1;" parent="1" source="ph_fatal" target="ph_sps" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a6" style="strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;" parent="1" source="ph_sps" target="ph_open" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Call chain -->
        <mxCell id="chain" value="&lt;b&gt;Call chain:&lt;/b&gt; SOA_CheckCellVoltage() → DIAG_Handler(DIAG_ID_CELLVOLTAGE_OV_MSL) → FATAL → BMS_Trigger() → BMS_ERROR → CONT_OpenAll() → spiREG2 → SPS IC → contactor spring-open" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#30363d;fontColor=#9ca3af;fontSize=8;align=left;spacingLeft=8;" parent="1" vertex="1">
          <mxGeometry x="60" y="180" width="840" height="25" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
