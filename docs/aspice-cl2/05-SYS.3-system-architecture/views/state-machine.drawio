        <mxCell id="subtitle" parent="1" style="text;fontSize=13;fontColor=#6e7681;align=left;" value="Managed by BMS_Trigger() in 100ms task | ERROR exit requires AND logic (SSR-022 + SSR-023)" vertex="1">
