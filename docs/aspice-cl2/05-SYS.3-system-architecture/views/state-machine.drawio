<mxfile host="VSCode" modified="2026-03-23T23:30:00.000Z" agent="Claude">
  <diagram id="bms-sm" name="BMS State Machine">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="850" background="#0d1117">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="BMS State Machine" style="text;fontSize=16;fontColor=#ffffff;fontStyle=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="10" width="300" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Managed by BMS_Trigger() in 100ms task | ERROR exit requires AND logic (SSR-022 + SSR-023)" style="text;fontSize=9;fontColor=#6e7681;align=left;" parent="1" vertex="1">
          <mxGeometry x="20" y="35" width="700" height="15" as="geometry"/>
        </mxCell>

        <!-- STANDBY -->
        <mxCell id="standby" value="STANDBY&#xa;&#xa;All contactors OPEN&#xa;Monitoring active&#xa;IVT current = 0 mA&#xa;&#xa;Entry: SYS==RUNNING or ERROR recovery" style="rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#58a6ff;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;align=center;" parent="1" vertex="1">
          <mxGeometry x="50" y="80" width="300" height="160" as="geometry"/>
        </mxCell>

        <!-- PRECHARGE -->
        <mxCell id="precharge_s" value="PRECHARGE&#xa;&#xa;1. Close STRING- (SPS CH1)&#xa;2. Close PRECHARGE (SPS CH2)&#xa;3. Wait V_dc ≈ V_pack (±1000mV)&#xa;4. Close STRING+ (SPS CH0), open PRE" style="rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#d29922;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;align=center;" parent="1" vertex="1">
          <mxGeometry x="500" y="80" width="350" height="160" as="geometry"/>
        </mxCell>

        <!-- NORMAL -->
        <mxCell id="normal" value="NORMAL&#xa;&#xa;All 3 contactors CLOSED&#xa;Full power operation&#xa;SOA checks active every 10ms&#xa;IVT current = load current" style="rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#3fb950;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;align=center;" parent="1" vertex="1">
          <mxGeometry x="500" y="350" width="350" height="150" as="geometry"/>
        </mxCell>

        <!-- ERROR -->
        <mxCell id="error" value="ERROR (Safe State)&#xa;&#xa;All contactors OPEN (CONT_OpenAll)&#xa;State is LATCHED — no auto-recover&#xa;&#xa;EXIT requires BOTH (AND logic):&#xa;SSR-022: Fault condition CLEARED&#xa;SSR-023: CAN 0x210 STANDBY request" style="rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#f85149;fontColor=#c9d1d9;fontSize=10;strokeWidth=3;align=center;" parent="1" vertex="1">
          <mxGeometry x="500" y="600" width="350" height="180" as="geometry"/>
        </mxCell>

        <!-- Transitions — ALL plain text, no HTML tags -->
        <mxCell id="t_s_p" value="CAN 0x210 = NORMAL request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=9;fontColor=#3fb950;fontStyle=1;" parent="1" source="standby" target="precharge_s" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="t_p_n" value="Voltage match within threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3fb950;strokeWidth=3;endArrow=block;endFill=1;fontSize=9;fontColor=#3fb950;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="precharge_s" target="normal" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="t_p_e" value="Timeout or 3 retries fail" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=2;dashed=1;dashPattern=6 3;endArrow=block;endFill=1;fontSize=8;fontColor=#f85149;exitX=1;exitY=1;entryX=1;entryY=0;" parent="1" source="precharge_s" target="error" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="t_n_s" value="CAN 0x210 = STANDBY request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;fontColor=#58a6ff;fontStyle=1;exitX=0;exitY=0.5;entryX=0;entryY=1;" parent="1" source="normal" target="standby" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="30" y="425"/><mxPoint x="30" y="240"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="t_n_e" value="ANY MSL violation (DIAG FATAL)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f85149;strokeWidth=3;endArrow=block;endFill=1;fontSize=9;fontColor=#f85149;fontStyle=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" parent="1" source="normal" target="error" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="t_e_s" value="Fault cleared AND STANDBY requested (SSR-022 + SSR-023)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#58a6ff;strokeWidth=2;dashed=1;dashPattern=8 4;endArrow=block;endFill=1;fontSize=8;fontColor=#58a6ff;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" parent="1" source="error" target="standby" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="200" y="690"/></Array>
          </mxGeometry>
        </mxCell>

        <!-- Fault sources — plain text, no HTML -->
        <mxCell id="faults" value="Faults that trigger ERROR:&#xa;&#xa;TSR-01: Cell OV > 2800mV (FTTI 750ms)&#xa;TSR-02: Cell UV &lt; 1500mV (FTTI 750ms)&#xa;TSR-04/05: Overcurrent (FTTI 250ms)&#xa;TSR-06/07: Over/undertemp (FTTI 6050ms)&#xa;TSR-08: Contactor FB mismatch (350ms)&#xa;TSR-09: IVT comms loss (1250ms)&#xa;TSR-10: AFE comms loss (200ms)&#xa;TSR-13: Interlock break (250ms)" style="rounded=1;whiteSpace=wrap;fillColor=#0d1117;strokeColor=#30363d;fontColor=#fca5a5;fontSize=9;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="950" y="350" width="280" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="w_faults" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f85149;strokeWidth=1;dashed=1;endArrow=block;endFill=1;" parent="1" source="faults" target="error" edge="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

