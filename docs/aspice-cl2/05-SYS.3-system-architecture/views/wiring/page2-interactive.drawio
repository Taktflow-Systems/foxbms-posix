        <mxCell id="sps_ic" value="&lt;b&gt;SPS IC&lt;/b&gt;&lt;br&gt;&lt;font size=&#39;1&#39; color=&#39;#9ca3af&#39;&gt;8-ch MOSFET driver&lt;br&gt;UVLO → fail-safe open&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="370" y="30" width="160" height="70" as="geometry" />
        </mxCell>
        <!-- SBC -->
        <mxCell id="sbc_p" value="&lt;b&gt;SBC FS8x&lt;/b&gt;&lt;br&gt;&lt;font size=&#39;1&#39; color=&#39;#9ca3af&#39;&gt;Watchdog | RSTB J9002.80&lt;br&gt;ASIL D qualified&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#d29922;fontColor=#d29922;fontSize=10;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="370" y="130" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- J200x -->
        <mxCell id="j200x_p" value="&lt;b&gt;J200x ×8&lt;/b&gt;&lt;br&gt;&lt;font size=&#39;1&#39; color=&#39;#9ca3af&#39;&gt;4-pin Micro-Fit each&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&#39;#d29922&#39;&gt;&lt;b&gt;Pin 1 FB&lt;/b&gt;&lt;/font&gt; | &lt;font color=&#39;#d29922&#39;&gt;&lt;b&gt;Pin 3 OUT&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font size=&#39;1&#39; color=&#39;#9ca3af&#39;&gt;Pin 2 SUP | Pin 4 GND&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font size=&#39;1&#39; color=&#39;#9ca3af&#39;&gt;CH0=String+ | CH1=String-&lt;/font&gt;&lt;br&gt;&lt;font color=&#39;#f85149&#39;&gt;&lt;b&gt;CH2=Precharge (NO FB!)&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#161b22;strokeColor=#d29922;fontColor=#d29922;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="660" y="20" width="220" height="170" as="geometry" />
        </mxCell>
        <!-- Wires -->
        <mxCell id="w4_spi" value="SPI2 →" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d29922;strokeWidth=3;endArrow=block;endFill=1;fontSize=8;fontColor=#d29922;" parent="1" source="spi2_p" target="sps_ic" edge="1">
