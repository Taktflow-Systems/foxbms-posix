          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w4_sbc" value="SPI2 shared →" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d29922;strokeWidth=1.5;dashed=1;dashPattern=6 3;endArrow=block;endFill=1;fontSize=7;fontColor=#d29922;" parent="1" source="spi2_p" target="sbc_p" edge="1">
