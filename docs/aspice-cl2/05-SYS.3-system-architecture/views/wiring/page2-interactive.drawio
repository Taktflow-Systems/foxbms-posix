          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="w4_fb" value="← FB via I2C PEX1 (p0=Str+, p1=Str-, p2=Pre)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#bc8cff;strokeWidth=1.5;dashed=1;dashPattern=5 3;endArrow=block;endFill=1;fontSize=7;fontColor=#bc8cff;exitX=1;exitY=0.5;entryX=0;entryY=0.8;" parent="1" source="i2c_sps" target="j200x_p" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- CONSTRAINT-001 -->
        <mxCell id="constraint" value="&lt;font color=&#39;#f85149&#39;&gt;&lt;b&gt;⚠ CONSTRAINT-001:&lt;/b&gt; SPS_Ctrl() must execute BEFORE SBC_Trigger() in 10ms task&lt;br&gt;GAP-08: SPS bypasses SPI_Lock (latent defect) | GAP-02: Precharge has NO_FEEDBACK | ftask_cfg.c lines 248/252&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0d1117;strokeColor=#f85149;fontColor=#9ca3af;fontSize=8;align=center;" parent="1" vertex="1">
